# =============================================================================
# AniStream API — environment variables (Vercel → Settings → Environment Vars)
# EVERYTHING here is OPTIONAL: the app boots with these exact defaults baked in.
# Only set a var if you want to override a domain or a limit.
# =============================================================================

# --- Anime sources (failover order = the order below) ------------------------
SOURCE_ANIWATCH_URL=https://ww2.aniwatch.fit
SOURCE_ANIMEPLAYTV_URL=https://animeplaytv.com
SOURCE_ANIMEPAHE_URL=https://animepahe.ch
SOURCE_SANKAVOLLEREI_URL=https://www.sankavollerei.web.id
SOURCE_NINEANIME_URL=https://9anime.org.lv
SOURCE_ANIXPL_URL=https://anix.com.pl

# --- Donghua sources (failover order) ----------------------------------------
SOURCE_DONGHUB_URL=https://donghub.vip
SOURCE_ANICHIN_URL=https://anichin.moe
SOURCE_ANICHINRO_URL=https://anichin.ro
# (sankavollerei donghua reuses SOURCE_SANKAVOLLEREI_URL above)

# --- Film sources ------------------------------------------------------------
# Both run the same generic GMR/muvipro adapter (iyengar = primary, evilseniors = backup).
SOURCE_IYENGAR_URL=https://iyengaryogacenter.com
SOURCE_EVILSENIORS_URL=https://evilseniors.com

# --- API behaviour -----------------------------------------------------------
# Comma-separated allowed CORS origins. Empty = allow all ("*").
CORS_ORIGINS=

# In-memory response cache TTL (seconds).
CACHE_TTL_SECONDS=300

# Per-IP rate limit.
RATE_LIMIT_MAX=60
RATE_LIMIT_WINDOW_SECONDS=60

# Per-scrape Axios timeout (ms). Keep < the Vercel 60s function cap.
HTTP_TIMEOUT_MS=15000
